{
  "name": "terminal-workspace-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "review": "vite --host 127.0.0.1 --port 5177 --strictPort true",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify:map-terminals": "node scripts/verify-map-terminals.mjs",
    "verify:canvas-terminal": "scripts/verify-canvas-terminal.sh",
    "verify:terminal-rendering": "node scripts/verify-terminal-rendering.mjs",
    "verify:tauri-dev-performance": "scripts/verify-tauri-dev-performance.sh",
    "verify:standalone-daemon": "scripts/verify-standalone-daemon-smoke.sh",
    "verify:daemon-latency": "node scripts/verify-daemon-latency.mjs",
    "verify:tauri-performance": "scripts/verify-tauri-performance.sh",
    "verify:native-terminal-deps": "scripts/verify-native-terminal-deps.sh",
    "verify:native-vte-build": "scripts/verify-native-vte-build.sh",
    "trace:terminal-latency": "node scripts/summarize-terminal-latency-trace.mjs",
    "verify:typography": "node scripts/verify-typography.mjs",
    "verify:visual": "scripts/verify-visual-evidence.sh",
    "tauri": "tauri",
    "tauri:dev:native-vte": "CARGO_BUILD_JOBS=${CARGO_BUILD_JOBS:-1} CARGO_PROFILE_DEV_DEBUG=${CARGO_PROFILE_DEV_DEBUG:-0} tauri dev --features native-vte",
    "verify:native-vte-runtime": "scripts/verify-native-vte-runtime.sh",
    "verify:native-vte-release-runtime": "NATIVE_VTE_RUNTIME_MODE=release scripts/verify-native-vte-runtime.sh",
    "verify:native-vte-visual-latency": "scripts/verify-native-vte-visual-latency.sh",
    "verify:native-vte-pixel-latency": "scripts/verify-native-vte-pixel-latency.sh",
    "verify:native-vte-lifecycle": "scripts/verify-native-vte-lifecycle.sh",
    "verify:native-vte-restart-reconnect": "scripts/verify-native-vte-restart-reconnect.sh"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/rubik": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2",
    "@xterm/addon-fit": "^0.10",
    "@xterm/addon-web-links": "^0.11",
    "@xterm/addon-webgl": "^0.18",
    "@xterm/xterm": "^5",
    "allotment": "^1.20.5",
    "lucide-react": "^1.16.0",
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^6"
  }
}
